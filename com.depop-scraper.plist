<?xml version="1.0" encoding="UTF-8"?>
<!--
  launchd template. You normally don't need to touch this — `python3 run.py setup`
  generates and loads it automatically with the right paths for your machine.
  To use it manually, replace /ABSOLUTE/PATH/TO/depop-scraper below with your clone
  path, and confirm the python3 path (run `which python3`).
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.depop-scraper</string>
    <key>ProgramArguments</key>
    <array>
        <string>/opt/homebrew/bin/python3</string>
        <string>/ABSOLUTE/PATH/TO/depop-scraper/run.py</string>
    </array>
    <key>StartInterval</key>
    <integer>1800</integer>
    <key>RunAtLoad</key>
    <true/>
    <key>StandardOutPath</key>
    <string>/ABSOLUTE/PATH/TO/depop-scraper/run.log</string>
    <key>StandardErrorPath</key>
    <string>/ABSOLUTE/PATH/TO/depop-scraper/run.log</string>
    <key>WorkingDirectory</key>
    <string>/ABSOLUTE/PATH/TO/depop-scraper</string>
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
    </dict>
</dict>
</plist>
