# Copy to .env and fill in your own values.

# Pick any unguessable string — this is YOUR private alert channel.
# Subscribe to it in the ntfy app (https://ntfy.sh) to receive buy alerts.
NTFY_TOPIC=your-unguessable-topic-here
NTFY_SERVER=https://ntfy.sh

# Optional. Without it the pipeline is pure rules (no LLM "maybe" judging).
# ANTHROPIC_API_KEY=sk-ant-...
